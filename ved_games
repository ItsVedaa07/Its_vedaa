<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Shooting Game</title>
  <style>
    body {
      background: #111;
      color: #eee;
      font-family: Arial, sans-serif;
      text-align: center;
      margin: 0;
      overflow: hidden;
    }
    #gameArea {
      position: relative;
      width: 100vw;
      height: 100vh;
      background: #222;
    }
    .target {
      position: absolute;
      width: 60px;
      height: 60px;
      background: red;
      border-radius: 50%;
      cursor: crosshair;
    }
    #score {
      position: absolute;
      top: 10px;
      left: 10px;
      font-size: 20px;
      color: #00ffcc;
    }
  </style>
</head>
<body>
  <div id="gameArea">
    <div id="score">Score: 0</div>
  </div>

  <script>
    const gameArea = document.getElementById("gameArea");
    const scoreDisplay = document.getElementById("score");
    let score = 0;

    function createTarget() {
      const target = document.createElement("div");
      target.classList.add("target");

      // Random position
      const x = Math.random() * (window.innerWidth - 60);
      const y = Math.random() * (window.innerHeight - 60);
      target.style.left = x + "px";
      target.style.top = y + "px";

      // Add to game area
      gameArea.appendChild(target);

      // Click to shoot
      target.addEventListener("click", () => {
        score++;
        scoreDisplay.textContent = "Score: " + score;
        target.remove();
      });

      // Remove after 2 seconds if not clicked
      setTimeout(() => {
        if (gameArea.contains(target)) {
          target.remove();
        }
      }, 2000);
    }

    // Spawn targets every second
    setInterval(createTarget, 1000);
  </script>
</body>
</html>
